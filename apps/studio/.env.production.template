# Ivaronix Studio · production env template
#
# Copy to `.env.production` (or set as Vercel env vars) before
# `vercel --prod`. Variables grouped by purpose; every line is either
# REQUIRED or has a documented default.
#
# All canonical names are `IVARONIX_*`. Legacy aliases (`EVM_*`, `ZG_*`,
# `OG_*`) still resolve so existing operator `.env` files don't break,
# but they print a one-time deprecation warning per alias used. Run
# `pnpm env:check` to see which canonical / alias resolved to your value.
#
# Source of truth: `packages/runtime/src/env.ts` SIGNER_KEY_ALIASES, etc.

# ─── Chain + receipts (REQUIRED) ────────────────────────────────────────
# The operator's signing key. Anchors receipts on Galileo + signs receipt
# bodies. Same key used in CLI dev. Never commit the real value.
# Legacy aliases: OG_PRIVATE_KEY, EVM_PRIVATE_KEY (still resolve, deprecated).
IVARONIX_SIGNER_KEY=0x...

# Operator wallet address (must derive from IVARONIX_SIGNER_KEY).
# Legacy alias: EVM_WALLET_ADDRESS.
IVARONIX_WALLET_ADDRESS=0x...

# Network selector. `testnet` for Galileo (chainId 16602), `mainnet` for
# Aristotle (chainId 16661). Default: testnet. Mainnet promotion gated
# on USER_TODO §B-V2 redeploy. Legacy alias: OG_NETWORK.
IVARONIX_NETWORK=testnet

# Chain ID — must match IVARONIX_NETWORK. testnet=16602, mainnet=16661.
# Legacy alias: OG_CHAIN_ID. Optional: defaults derive from network when
# unset, but explicit pin defends against testnet/mainnet mix-ups.
IVARONIX_CHAIN_ID=16602

# Optional RPC override. When unset, the runtime uses 0G's canonical
# RPCs from `packages/og-chain/src/networks.ts`. Legacy alias: OG_RPC_URL.
# IVARONIX_RPC_URL=https://evmrpc-testnet.0g.ai

# ─── Read-proxy key (OPTIONAL · privacy hardening) ─────────────────────
# Per docs/PRIVACY_NOTES.md §1: separate signing key for storage-indexer
# auth on public-fetch paths. Without it, the operator wallet appears in
# indexer logs for every blob fetch — including blobs the operator isn't
# a party to (data-room reads, dashboard reads). With it, only writes.
# Generate a fresh ZERO-BALANCE wallet (no funding needed). Legacy alias:
# READ_PROXY_PRIVATE_KEY.
# IVARONIX_READ_PROXY_KEY=0x...

# ─── 0G Compute / Router (TIER 1 path · REQUIRED for TEE-attested inference) ─
# All three required together; missing any one falls back to TIER 2 NVIDIA.
# Legacy aliases: ZG_API_SECRET, ZG_SERVICE_URL, OG_COMPUTE_PROVIDER.
IVARONIX_ROUTER_KEY=
IVARONIX_ROUTER_URL=https://compute-network-1.integratenetwork.work/v1/proxy
IVARONIX_ROUTER_PROVIDER=0x...

# Default inference model. Override per-run via `--model` (CLI) or
# `model` field (API). Legacy alias: OG_DEFAULT_MODEL.
IVARONIX_DEFAULT_MODEL=qwen/qwen-2.5-7b-instruct

# ─── NVIDIA NIM (TIER 2 fallback · OPTIONAL · external-signed) ──────────
# When set, RunPanel can route to NIM with `provider: 'nvidia'`. Receipts
# correctly tagged `tier-2-external-signed` per CLAUDE.md §6.
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_DEFAULT_MODEL=qwen/qwen3.5-397b-a17b

# ─── Authentication + rate limit (K-8 + K-9) ────────────────────────────
# Required for multi-instance Vercel deployments. The session HMAC is
# random per-process otherwise — sessions don't survive restarts and don't
# cross instances. Set to a stable 32+ char secret here.
IVARONIX_SESSION_SECRET=change-me-to-a-32-char-secret-string

# Optional: Upstash Redis for shared rate-limit buckets across instances.
# When unset, the in-memory token bucket runs per-instance (acceptable for
# single-instance dev; production multi-instance should pin these).
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Operator-mode anonymous-run budget cap (K-8). When exceeded the route
# returns 429 even before per-IP buckets fire. Default: 0.5 OG/day.
# OPERATOR_DAILY_OG_CAP=0.5

# ─── 0G Persistent Memory sidecar (OPTIONAL · H-4) ──────────────────────
# When set, `runPipeline` searches + stores episodic memories per skill +
# wallet. When unset, every run is contextless and the receipt body
# honestly omits `request.memoryQuery`.
# ZG_MEMORY_URL=http://localhost:1995

# ─── 0G DA disperser (OPTIONAL · planning-003 §A.5.21) ──────────────────
# When set + the local disperser container (per docker-compose.yml) is
# reachable, `ivaronix da disperse` anchors receipt evidence on 0G DA.
# When unset, the receipt body omits `storage.daBlobRef`.
# ZG_DA_URL=localhost:51001

# ─── 0G Storage (OPTIONAL · H-3 follow-up) ──────────────────────────────
# Indexer + storage RPC. When set + reachable, /api/run uploads encrypted
# evidence and the Storage light goes green. Until H-3 lands, the in-memory
# burn ciphertext (per K-16) is honestly retained without an upload.
# Canonical alias: IVARONIX_STORAGE_INDEXER. Legacy: ZG_STORAGE_INDEXER.
# IVARONIX_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
# ZG_STORAGE_RPCS=https://rpc-storage-testnet-turbo.0g.ai

# ─── Local 0G KV dev container (OPTIONAL) ──────────────────────────────
# Used by `pnpm dev:kv` and apps/cli doctor/debug. Default port 6789
# matches docker-compose.yml. Set IVARONIX_KV_URL when the production
# KV server JSON-RPC endpoint is reachable for durable persistence
# (queued · per HALF_BAKED.md the production wire-up is opt-in).
# IVARONIX_KV_PORT=6789
# IVARONIX_KV_URL=http://localhost:6789

# ─── Studio surface (OPTIONAL) ──────────────────────────────────────────
# Public base URL for cross-machine receipt links + embed widgets. The
# `@ivaronix/widget` package's DEFAULT_ORIGIN reads this at build time so
# embedded widgets point at the production URL. Set to your Vercel-assigned
# domain after USER_TODO §C-3 lands.
# IVARONIX_STUDIO_BASE=https://ivaronix.vercel.app
#
# NEXT_PUBLIC_BASE_URL is consumed by apps/studio's metadataBase
# (apps/studio/src/app/layout.tsx) + print-page verify URL + embed-page
# "View full receipt" link. If unset, the Studio falls back through the
# Vercel-env chain: VERCEL_PROJECT_PRODUCTION_URL → VERCEL_URL → localhost.
# Set this ONLY if you've promoted to a custom domain that Vercel isn't
# aware of (e.g. you've put Cloudflare in front and want OG cards to
# point at the Cloudflare URL).
# NEXT_PUBLIC_BASE_URL=https://your-custom-domain.example

# ─── Sentry (OPTIONAL but recommended for prod) ─────────────────────────
# Server-side error capture. When unset, errors only land in Vercel logs.
# SENTRY_DSN=https://...sentry.io/...
# SENTRY_ENVIRONMENT=production

# ─── Node env (REQUIRED) ────────────────────────────────────────────────
NODE_ENV=production
