{
  "name": "ivaronix",
  "private": true,
  "version": "0.0.1",
  "description": "The 0G Agent Operating System. Catch the risks. Keep the receipts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pratiikpy/ivaronix.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "ivaronix": "pnpm --filter @ivaronix/cli exec ivaronix",
    "doctor": "pnpm --filter @ivaronix/cli exec ivaronix doctor",
    "wording-lint": "tsx scripts/wording-lint.ts",
    "numbers:refresh": "tsx scripts/diag/numbers-refresh.ts",
    "numbers:print": "tsx scripts/diag/numbers-refresh.ts --print",
    "numbers:check": "tsx scripts/diag/numbers-refresh.ts --check",
    "screenshots:refresh": "pnpm --filter qa-metamask-e2e exec tsx capture-readme-shots.ts",
    "tour:refresh": "pnpm --filter qa-metamask-e2e exec tsx capture-readme-tour.ts",
    "receipt-types:render": "tsx scripts/diag/render-receipt-types.ts",
    "receipt-types:check": "tsx scripts/diag/render-receipt-types.ts --check",
    "audit:list": "tsx scripts/diag/audit-list.ts",
    "brand:check": "tsx scripts/qa/metamask-e2e/verify-brand-token-drift.ts",
    "brand:check:update": "tsx scripts/qa/metamask-e2e/verify-brand-token-drift.ts --update-amnesty",
    "env:check": "tsx scripts/diag/env-check.ts",
    "og-font:regenerate": "tsx scripts/diag/regenerate-og-font-b64.ts",
    "og-font:verify": "tsx scripts/diag/verify-og-font-b64.ts",
    "docs:render": "tsx scripts/diag/docs-render.ts",
    "docs:check": "tsx scripts/diag/docs-render.ts --check",
    "wander:cycle": "tsx scripts/wander-cycle/cycle.ts",
    "wander:loop": "tsx scripts/wander-cycle/loop.ts",
    "dev:kv": "tsx scripts/dev/start-local-0g-kv.ts",
    "dev:kv:stop": "docker rm -f ivaronix-kv-node"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "es5-ext",
      "esbuild",
      "blake-hash",
      "bufferutil",
      "utf-8-validate"
    ],
    "_zodComment": "PASS 77 F-1h-f: per-package versions are correct (3.x for our code, 4.x for opencode-*). overrides only here if drift becomes a problem."
  }
}
