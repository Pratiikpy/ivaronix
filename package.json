{
  "name": "ivaronix",
  "private": true,
  "version": "0.0.1",
  "description": "The 0G Agent Operating System. Catch the risks. Keep the receipts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pratiikpy/ivaronix.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "ivaronix": "pnpm --filter @ivaronix/cli exec ivaronix",
    "doctor": "pnpm --filter @ivaronix/cli exec ivaronix doctor",
    "wording-lint": "tsx scripts/wording-lint.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "es5-ext",
      "esbuild",
      "blake-hash",
      "bufferutil",
      "utf-8-validate"
    ]
  }
}
