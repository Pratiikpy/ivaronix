# Line-ending policy. Without this, Windows checkouts get CRLF and
# Linux/macOS get LF; CI typecheck + diff-noise + 'LF will be replaced
# by CRLF' warnings on every commit. With it, every committed file is
# stored with LF in the index regardless of OS, and Windows checkouts
# only get CRLF for the file types that genuinely need them (.cmd, .bat).

# Default: auto-detect text vs binary; commit text with LF.
* text=auto eol=lf

# Source code — always LF.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.sol text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.txt text eol=lf

# Windows-specific scripts that REQUIRE CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binaries — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.webm binary
*.mp4 binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.gz binary
*.wav binary
*.pyc binary
