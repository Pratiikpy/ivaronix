{
  "name": "@ivaronix/og-toolkit",
  "version": "0.0.1",
  "description": "Receipt-aware-by-default DX wrappers for 0G — one import, every action gets a verifiable Action Receipt anchored on chain.",
  "license": "Apache-2.0",
  "homepage": "https://ivaronix.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pratiikpy/ivaronix"
  },
  "keywords": [
    "0g",
    "ai-agent",
    "verifiable-ai",
    "receipts",
    "tee",
    "consensus",
    "agent-framework"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "echo skip",
    "test": "echo skip",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc -b",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@ivaronix/core": "workspace:*",
    "@ivaronix/og-chain": "workspace:*",
    "@ivaronix/og-storage": "workspace:*",
    "@ivaronix/og-router": "workspace:*",
    "@ivaronix/og-kv": "workspace:*",
    "@ivaronix/runtime": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
