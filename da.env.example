# 0G DA local-disperser env (planning-003 §A.5.21 · corrected 2026-05-14)
#
# Copy to `da.env` and fill in. Used by `docker-compose.yml`'s da-client
# service. The container reads this file via `env_file:` at startup.
#
# Env var names + the entrance address below come from 0G's official
# integration doc:
#   oglabs resources/0g-doc/docs/developer-hub/building-on-0g/da-integration.md
#
# The `ghcr.io/0glabs/0g-da-client:latest` image is NOT publicly pullable
# (registry returns "denied" anonymously). The 0G team distributes the
# DA client via source build:
#
#   git clone https://github.com/0gfoundation/0g-da-client.git
#   cd 0g-da-client && docker build -t 0g-da-client -f combined.Dockerfile .
#
# After building, point docker-compose.yml at the local image
# (`image: 0g-da-client` instead of the ghcr.io path).
#
# Generate a fresh DA wallet (do NOT reuse the operator signer key per
# `docs/PRIVACY_NOTES.md` §1):
#   pnpm exec tsx -e 'import {Wallet} from "ethers"; const w=Wallet.createRandom(); console.log(w.address); console.log(w.privateKey);'

# Required: chain RPC the DA client uses to verify finalization on chain.
COMBINED_SERVER_CHAIN_RPC=https://evmrpc-testnet.0g.ai

# Required: DA disperser-signing key (32-byte hex, NO 0x prefix).
# Fund this wallet with ~0.005 OG before running disperse.
COMBINED_SERVER_PRIVATE_KEY=

# Required: DA entrance contract address per 0G's integration doc.
# Galileo testnet (chainId 16602):
ENTRANCE_CONTRACT_ADDR=0x857C0A28A8634614BB2C96039Cf4a20AFF709Aa9
# Mainnet (chainId 16661): <TBD when 0G mainnet DA goes live>

# Required: DASigners precompile address (fixed across networks).
BATCHER_DASIGNERS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000001000

# Disperser tuning per 0G default.
COMBINED_SERVER_RECEIPT_POLLING_ROUNDS=180
COMBINED_SERVER_RECEIPT_POLLING_INTERVAL=1s
COMBINED_SERVER_TX_GAS_LIMIT=2000000
COMBINED_SERVER_USE_MEMORY_DB=true
COMBINED_SERVER_KV_DB_PATH=/runtime/
COMBINED_SERVER_TimeToExpire=2592000
DISPERSER_SERVER_GRPC_PORT=51001
BATCHER_FINALIZER_INTERVAL=20s
BATCHER_CONFIRMER_NUM=3
BATCHER_MAX_NUM_RETRIES_PER_BLOB=3
