# 0G DA local-disperser env (planning-003 §A.5.21)
#
# Copy to `da.env` and fill in. Used by `docker-compose.yml`'s da-client
# service. The container reads this file via `env_file:` at startup.
#
# Generate a fresh DA wallet (do NOT reuse the operator signer key per
# `docs/PRIVACY_NOTES.md` §1):
#   node -e 'const{Wallet}=require("ethers");const w=Wallet.createRandom();console.log(w.address);console.log(w.privateKey);'

# DA disperser-signing key (32-byte hex, NO 0x prefix per 0g-da-client convention).
# Fund this wallet with ~0.005 OG before running disperse.
DA_PRIVATE_KEY=

# 0G Chain RPC the DA client uses to verify finalization on chain.
# Galileo testnet:
DA_RPC_URL=https://evmrpc-testnet.0g.ai
# Mainnet (when you flip):
# DA_RPC_URL=https://evmrpc.0g.ai

# DA entrance contract address. Per 0G docs · verified 2026-05-14 in
# oglabs resources/0g-doc/docs/developer-hub/testnet/testnet-overview.md
# Galileo testnet (chainId 16602):
DA_ENTRANCE_CONTRACT=0xE75A073dA5bb7b0eC622170Fd268f35E675a957B
# Mainnet (chainId 16661):
# DA_ENTRANCE_CONTRACT=<TBD when 0G mainnet DA goes live>

# Optional — log level for the disperser process.
DA_LOG_LEVEL=info
