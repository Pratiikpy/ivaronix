# Ivaronix · Environment Variables Template
#
# Copy this file to `.env` (gitignored) and fill in real values.
# NEVER commit `.env`. NEVER paste real values into chat.
#
# All canonical names are `IVARONIX_*`. Legacy aliases (`OG_*`,
# `EVM_*`, `ZG_*`) still resolve so existing operator `.env` files
# don't break, but they print a one-time deprecation warning per alias
# used. Run `pnpm env:check` to see which canonical / alias resolved
# to your value, color-coded green (canonical), yellow (legacy alias),
# red (unset).
#
# Source of truth: packages/runtime/src/env.ts SIGNER_KEY_ALIASES, etc.

# ─── Network selection ──────────────────────────────────────────────
# `testnet` (Galileo, chainId 16602) or `mainnet` (Aristotle, 16661).
# Mainnet promotion gated on USER_TODO §B-V2 redeploy.
IVARONIX_NETWORK=testnet
IVARONIX_CHAIN_ID=16602

# ─── RPC override (optional) ────────────────────────────────────────
# Default resolves from packages/og-chain/src/networks.ts when unset:
#   testnet → https://evmrpc-testnet.0g.ai
#   mainnet → https://evmrpc.0g.ai
# IVARONIX_RPC_URL=https://evmrpc-testnet.0g.ai

# ─── Operator signing wallet (REQUIRED for any chain write) ─────────
# 32-byte hex with 0x prefix. Generate fresh:
#   node -e 'const{Wallet}=require("ethers");const w=Wallet.createRandom();console.log(w.address);console.log(w.privateKey);'
# Fund at https://faucet.0g.ai (testnet) or via CEX bridge (mainnet).
# Legacy aliases: OG_PRIVATE_KEY, EVM_PRIVATE_KEY (still resolve, deprecated).
IVARONIX_SIGNER_KEY=0x...

# Operator wallet address (must derive from IVARONIX_SIGNER_KEY).
# Legacy alias: EVM_WALLET_ADDRESS.
IVARONIX_WALLET_ADDRESS=0x...

# Admin wallet for /admin/treasury and other privileged Studio routes
# (FINAL_BUILD_PLAN.md D-5 · Block I). Defaults to IVARONIX_WALLET_ADDRESS
# when unset. Must match the SkillRunPayment.owner() on chain for the
# admin route's authorization gate to grant access.
IVARONIX_ADMIN_WALLET=0x...

# Demo wallet for /?demo=true subsidised runs (FINAL_BUILD_PLAN.md Block E).
# Falls back to IVARONIX_SIGNER_KEY when unset. Keep balance > 0.05 OG;
# the demo-wallet-monitor cron alerts when low.
# DEMO_WALLET_KEY=0x...

# 0G KV server self-host (FINAL_BUILD_PLAN.md Block F). When set, Studio's
# createKvClient() returns HttpKvClient against this endpoint instead of
# the in-memory stub. See infra/0g-kv/README.md for self-host runbook.
# KV_REMOTE_URL=http://localhost:1995
# KV_ISSUER_API_KEY=...    # bootstrap key for /api/memory/key user registration
# KV_API_KEY=...           # per-user key for server-side test runs

# Goldsky subgraph endpoint (FINAL_BUILD_PLAN.md Block O). When set, the
# marketplace pages + dashboard query through Goldsky for fast indexed
# reads. When unset, the marketplace falls back to direct-chain reads
# (slower but functional). See subgraph/README.md for deploy runbook.
# SUBGRAPH_URL=https://api.goldsky.com/api/public/<project>/subgraphs/ivaronix/<version>/gn

# Telegram alerts for demo-wallet-monitor (FINAL_BUILD_PLAN.md D-6).
# When both set, demo wallet running low triggers alerts to operator.
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_OPERATOR_CHAT_ID=...

# ─── Read-proxy key (optional · privacy hardening) ───────────────────
# Per docs/PRIVACY_NOTES.md §1: separate signing key for storage-indexer
# auth on public-fetch paths. Without it, the operator wallet appears
# in indexer logs for every blob fetch — including blobs the operator
# isn't a party to (data-room reads, dashboard reads). With it, the
# operator wallet only appears for actual writes (uploads, anchors).
#
# Generate a fresh ZERO-BALANCE wallet (no funding needed — indexer
# auth signs the request, doesn't pay gas). Same node -e command as
# above.
# Legacy alias: READ_PROXY_PRIVATE_KEY.
# IVARONIX_READ_PROXY_KEY=0x...

# ─── 0G Router (TIER 1 · TEE-attested inference path · REQUIRED for /run) ─
# All three required together; missing any one falls back to TIER 2 NVIDIA.
# Legacy aliases: ZG_API_SECRET, ZG_SERVICE_URL, OG_COMPUTE_PROVIDER.
IVARONIX_ROUTER_KEY=
IVARONIX_ROUTER_URL=https://compute-network-1.integratenetwork.work/v1/proxy
IVARONIX_ROUTER_PROVIDER=0x...

# ─── Default inference model ────────────────────────────────────────
# Override per-run via `--model` (CLI) or `model` field (API). Legacy
# alias: OG_DEFAULT_MODEL.
IVARONIX_DEFAULT_MODEL=0GM-1.0-35B-A3B

# ─── NVIDIA NIM · TIER 2 fallback (optional · external-signed) ───────
# When set, the runtime can route to NIM with `provider: 'nvidia'` per
# CLAUDE.md §6 honest tier disclosure. Receipts correctly tag
# `verificationMethod: 'external-signed'` and render in amber.
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_DEFAULT_MODEL=qwen/qwen3.5-397b-a17b

# ─── 0G Storage indexer override (optional) ──────────────────────────
# Default resolves from packages/og-storage based on IVARONIX_NETWORK.
# IVARONIX_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# ─── 0G DA local disperser endpoint (optional) ───────────────────────
# Set when running the local 0g-da-client docker container per
# `docker-compose.yml` (planning-003 §A.5.21). Defaults to localhost:51001.
# Aliases: ZG_DA_URL, ZG_DA_ENDPOINT.
# ZG_DA_URL=localhost:51001

# ─── GitHub token (optional · for 0g-integration-auditor skill) ──────
# Scope: public_repo (read-only). Generate a classic token at
# https://github.com/settings/tokens. Used only when the skill needs
# to clone or scan a repo; unset is fine for most flows.
# GITHUB_TOKEN=ghp_...

# ─── Studio public origin (post-deploy) ─────────────────────────────
# Set in Vercel env vars after the custom domain lands per
# USER_TODO §C-3. The widget package's DEFAULT_ORIGIN reads this at
# build time so embedded widgets point at the production URL.
# IVARONIX_STUDIO_BASE=https://ivaronix-studio.vercel.app

# ─── Studio session cookie HMAC secret (REQUIRED for SIWE) ──────────
# Used by apps/studio/src/lib/siwe-session.ts to sign the session
# cookie. 32+ char random string. Generate with:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
# When unset, SIWE sessions don't survive process restarts and don't
# cross instances on multi-instance Vercel deployments.
# IVARONIX_SESSION_SECRET=

# ─── Local 0G KV dev container (optional) ───────────────────────────
# Used by `pnpm dev:kv` and `apps/cli` doctor/debug commands. Default
# port 6789 matches docker-compose.yml. Set IVARONIX_KV_URL when the
# 0G KV server JSON-RPC endpoint is reachable for durable persistence
# (queued · per HALF_BAKED.md the production wire-up is opt-in).
# IVARONIX_KV_PORT=6789
# IVARONIX_KV_URL=http://localhost:6789

# ─── CLI deprecation-banner suppression (optional) ──────────────────
# Set to silence the "N legacy aliases in use" banner that loadEnv()
# emits when any OG_*/EVM_*/ZG_* alias still resolves. The banner is
# a one-liner per process invocation by default; set this flag once
# you've acknowledged the migration plan (planning-003 §A.3.4).
# IVARONIX_QUIET_ALIAS_WARNINGS=1
