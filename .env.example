# Ivaronix — Environment Variables Template
# Copy this file to `.env` (gitignored) and fill in real values.
# NEVER commit `.env`. NEVER paste real values into chat.

# === Network selection (testnet for Phase A, mainnet for Phase B) ===
OG_NETWORK=testnet

# === Galileo Testnet (Phase A) ===
OG_CHAIN_ID=16602
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_EXPLORER=https://chainscan-galileo.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_ROUTER_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
OG_DEFAULT_MODEL=qwen/qwen-2.5-7b-instruct

# === Aristotle Mainnet (Phase B — uncomment when promoting) ===
# OG_CHAIN_ID=16661
# OG_RPC_URL=https://evmrpc.0g.ai
# OG_CHAIN_EXPLORER=https://chainscan.0g.ai
# OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai
# OG_ROUTER_BASE_URL=https://router-api.0g.ai/v1

# === Wallet (deployer + signer) ===
# Same wallet that has the testnet OG balance. Already in your existing .env per 0G_TESTNET_NOTES.md.
OG_PRIVATE_KEY=0x_your_private_key_here_NEVER_COMMIT

# === 0G Router API key ===
# Get from 0G Router dashboard (TBD URL — likely https://router-api.0g.ai/dashboard or 0g.ai/router)
# Tied to your wallet; spends from deposited 0G Router balance.
OG_ROUTER_API_KEY=or_your_router_api_key_here

# === GitHub token (for 0g-integration-auditor skill) ===
# scope: public_repo (read-only). Generate at github.com/settings/tokens (classic).
GITHUB_TOKEN=ghp_your_fresh_token_here

# === Vercel (for Studio + API deploy — added closer to Day 13) ===
# VERCEL_TOKEN=

# === npm publish (deferred — local testing only for now per user direction) ===
# NPM_TOKEN=

# === Daemon settings (defaults are fine) ===
IVARONIX_DAEMON_PORT=8787
IVARONIX_LOG_DIR=~/.ivaronix/logs
